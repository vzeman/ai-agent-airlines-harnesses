{
  "name": "airline-agent-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "cli": "tsx src/cli.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "test:routes": "node scripts/test-route-matrix.mjs",
    "test:cookies": "node scripts/test-cookie-consent.mjs",
    "verify": "npm run check && npm test"
  },
  "dependencies": {
    "playwright-core": "1.52.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3"
  },
  "engines": {
    "node": ">=20"
  }
}
